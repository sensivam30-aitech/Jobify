      <div class="hero-stat-val">3+</div>
      <div class="hero-stat-label">Job Sources</div>
    </div>
    <div class="hero-stat-divider"></div>
    <div class="hero-stat">
      <div class="hero-stat-val">AI</div>
      <div class="hero-stat-label">Powered by Claude</div>
    </div>
    <div class="hero-stat-divider"></div>
    <div class="hero-stat">
      <div class="hero-stat-val">88%</div>
      <div class="hero-stat-label">Top Match Score</div>
    </div>
    <div class="hero-stat-divider"></div>
    <div class="hero-stat">
      <div class="hero-stat-val">Live</div>
      <div class="hero-stat-label">Real-Time Data</div>
    </div>
  </div>
</section>

<!-- ─── SOURCES STRIP ─── -->
<div class="sources-strip">
  <div class="sources-inner">
    <span class="sources-label">Powered by</span>
    <div class="source-item">
      <div class="source-item-icon si-indeed">i</div>
      Indeed
    </div>
    <div class="source-item">
      <div class="source-item-icon si-linkedin">in</div>
      LinkedIn
    </div>
    <div class="source-item">
      <div class="source-item-icon si-google">G</div>
      Google Jobs
    </div>
    <div class="source-item">
      <div class="source-item-icon si-claude">✦</div>
      Claude AI
    </div>
