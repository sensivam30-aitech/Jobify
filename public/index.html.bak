<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title>Jobify — Browse. Scrape. Succeed.</title>
<meta name="description" content="Jobify uses AI to scrape live job listings and match them to your résumé. Find your best opportunities across Indeed, LinkedIn and Google Jobs." />
<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500;0,9..40,600;1,9..40,300&family=DM+Mono:wght@400;500&display=swap" rel="stylesheet" />
<style>
  :root {
    --bg: #0a0a0f;
    --surface: #111118;
    --surface2: #1a1a24;
    --border: #22222f;
    --border2: #2e2e40;
    --accent: #00e5a0;
    --accent2: #7b61ff;
    --accent3: #ff6b35;
    --text: #e8e8f0;
    --text2: #8888a8;
    --text3: #55556a;
    --success: #00e5a0;
    --warn: #ffc947;
    --danger: #ff4757;
    --radius: 12px;
    --mono: 'DM Mono', monospace;
    --sans: 'DM Sans', sans-serif;
    --display: 'Bebas Neue', sans-serif;
  }

  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
  html { scroll-behavior: smooth; }

  body {
    background: var(--bg);
    color: var(--text);
    font-family: var(--sans);
    font-size: 15px;
    line-height: 1.6;
    min-height: 100vh;
    overflow-x: hidden;
  }

  /* ─── GRID BG ─── */
  body::before {
    content: '';
    position: fixed;
    inset: 0;
    background-image:
      linear-gradient(var(--border) 1px, transparent 1px),
      linear-gradient(90deg, var(--border) 1px, transparent 1px);
    background-size: 48px 48px;
    opacity: 0.35;
    pointer-events: none;
    z-index: 0;
  }

  /* ─── NAV ─── */
  nav {
    position: fixed;
    top: 0; left: 0; right: 0;
    z-index: 100;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0 48px;
    height: 64px;
    background: rgba(10,10,15,0.85);
    backdrop-filter: blur(16px);
    border-bottom: 1px solid var(--border);
  }

  .nav-logo {
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .nav-dot {
    width: 8px; height: 8px;
    border-radius: 50%;
    background: var(--accent);
    box-shadow: 0 0 10px var(--accent);
  }

  .nav-logo-text {
    font-family: var(--display);
    font-size: 28px;
    letter-spacing: 2px;
    color: var(--text);
    line-height: 1;
  }

  .nav-links {
    display: flex;
    align-items: center;
    gap: 32px;
  }

  .nav-links a {
    color: var(--text2);
    text-decoration: none;
    font-size: 13px;
    font-weight: 500;
    transition: color 0.2s;
    letter-spacing: 0.3px;
  }

  .nav-links a:hover { color: var(--accent); }

  .nav-cta {
    padding: 8px 20px;
    background: var(--accent);
    color: #0a0a0f !important;
    border-radius: 7px;
    font-weight: 600 !important;
    font-size: 13px !important;
    transition: all 0.2s !important;
  }

  .nav-cta:hover {
    background: #00ffb3 !important;
    box-shadow: 0 0 20px rgba(0,229,160,0.35);
    color: #0a0a0f !important;
  }

  /* ─── HERO ─── */
  .hero {
    position: relative;
    z-index: 1;
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    padding: 120px 24px 80px;
    overflow: hidden;
  }

  /* Orb glows */
  .hero::before {
    content: '';
    position: absolute;
    top: 10%; left: 50%;
    transform: translateX(-50%);
    width: 700px; height: 700px;
    background: radial-gradient(ellipse, rgba(0,229,160,0.08) 0%, rgba(123,97,255,0.04) 40%, transparent 70%);
    pointer-events: none;
  }

  .hero::after {
    content: '';
    position: absolute;
    bottom: 0; right: -10%;
    width: 400px; height: 400px;
    background: radial-gradient(ellipse, rgba(123,97,255,0.07) 0%, transparent 65%);
    pointer-events: none;
  }

  .hero-badge {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 6px 16px;
    border: 1px solid rgba(0,229,160,0.3);
    border-radius: 100px;
    background: rgba(0,229,160,0.05);
    font-family: var(--mono);
    font-size: 11px;
    color: var(--accent);
    letter-spacing: 1.5px;
    text-transform: uppercase;
    margin-bottom: 32px;
    animation: fadeUp 0.6s ease both;
  }

  .badge-dot {
    width: 6px; height: 6px;
    border-radius: 50%;
    background: var(--accent);
    animation: blink 1.5s ease-in-out infinite;
  }

  @keyframes blink {
    0%,100% { opacity: 1; }
    50% { opacity: 0.3; }
  }

  .hero-title {
    font-family: var(--display);
    font-size: clamp(64px, 10vw, 120px);
    line-height: 0.95;
    letter-spacing: 3px;
    color: var(--text);
    margin-bottom: 12px;
    animation: fadeUp 0.6s 0.1s ease both;
  }

  .hero-title span {
    background: linear-gradient(135deg, var(--accent), var(--accent2));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .hero-tagline {
    font-family: var(--display);
    font-size: clamp(20px, 3vw, 32px);
    letter-spacing: 4px;
    color: var(--text3);
    margin-bottom: 28px;
    animation: fadeUp 0.6s 0.15s ease both;
  }

  .hero-sub {
    max-width: 560px;
    font-size: 16px;
    color: var(--text2);
    line-height: 1.8;
    margin-bottom: 44px;
    animation: fadeUp 0.6s 0.2s ease both;
  }

  .hero-sub strong { color: var(--text); font-weight: 600; }

  .hero-cta-row {
    display: flex;
    align-items: center;
    gap: 16px;
    flex-wrap: wrap;
    justify-content: center;
    animation: fadeUp 0.6s 0.25s ease both;
    margin-bottom: 64px;
  }

  .btn-hero-primary {
    padding: 15px 36px;
    background: var(--accent);
    color: #0a0a0f;
    border: none;
    border-radius: 10px;
    font-family: var(--display);
    font-size: 20px;
    letter-spacing: 2px;
    cursor: pointer;
    transition: all 0.25s;
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    gap: 10px;
  }

  .btn-hero-primary:hover {
    background: #00ffb3;
    box-shadow: 0 0 40px rgba(0,229,160,0.4);
    transform: translateY(-2px);
  }

  .btn-hero-secondary {
    padding: 14px 28px;
    background: transparent;
    color: var(--text2);
    border: 1px solid var(--border2);
    border-radius: 10px;
    font-size: 14px;
    font-weight: 500;
    cursor: pointer;
    transition: all 0.2s;
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    gap: 8px;
  }

  .btn-hero-secondary:hover {
    border-color: var(--accent);
    color: var(--accent);
  }

  /* ─── STATS ROW ─── */
  .hero-stats {
    display: flex;
    align-items: center;
    gap: 48px;
    animation: fadeUp 0.6s 0.3s ease both;
  }

  .hero-stat {
    text-align: center;
  }

  .hero-stat-val {
    font-family: var(--display);
    font-size: 36px;
    letter-spacing: 1px;
    color: var(--accent);
    line-height: 1;
  }

  .hero-stat-label {
    font-size: 11px;
    color: var(--text3);
    text-transform: uppercase;
    letter-spacing: 1px;
    margin-top: 4px;
    font-family: var(--mono);
  }

  .hero-stat-divider {
    width: 1px;
    height: 40px;
    background: var(--border2);
  }

  /* ─── HOW IT WORKS ─── */
  .section {
    position: relative;
    z-index: 1;
    max-width: 1100px;
    margin: 0 auto;
    padding: 80px 24px;
  }

  .section-label {
    font-family: var(--mono);
    font-size: 10px;
    color: var(--accent);
    letter-spacing: 2px;
    text-transform: uppercase;
    margin-bottom: 10px;
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .section-label::after {
    content: '';
    flex: 1;
    height: 1px;
    background: var(--border);
  }

  .section-title {
    font-family: var(--display);
    font-size: clamp(36px, 5vw, 56px);
    letter-spacing: 2px;
    margin-bottom: 12px;
    color: var(--text);
  }

  .section-sub {
    color: var(--text2);
    font-size: 15px;
    max-width: 520px;
    margin-bottom: 56px;
    line-height: 1.7;
  }

  /* Steps */
  .steps-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
    margin-bottom: 80px;
  }

  @media (max-width: 768px) { .steps-grid { grid-template-columns: 1fr; } }

  .step-card {
    background: var(--surface);
    border: 1px solid var(--border2);
    border-radius: var(--radius);
    padding: 32px 28px;
    position: relative;
    overflow: hidden;
    transition: border-color 0.3s, transform 0.3s;
  }

  .step-card:hover {
    border-color: var(--accent);
    transform: translateY(-4px);
  }

  .step-card::before {
    content: '';
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 2px;
    background: linear-gradient(90deg, var(--accent), transparent);
    opacity: 0;
    transition: opacity 0.3s;
  }

  .step-card:hover::before { opacity: 1; }

  .step-number {
    font-family: var(--display);
    font-size: 64px;
    color: var(--border2);
    line-height: 1;
    margin-bottom: 16px;
    letter-spacing: 2px;
    transition: color 0.3s;
  }

  .step-card:hover .step-number { color: rgba(0,229,160,0.15); }

  .step-icon {
    font-size: 28px;
    margin-bottom: 14px;
    display: block;
  }

  .step-title {
    font-family: var(--display);
    font-size: 22px;
    letter-spacing: 1px;
    margin-bottom: 10px;
    color: var(--text);
  }

  .step-desc {
    font-size: 13px;
    color: var(--text2);
    line-height: 1.8;
  }

  /* ─── FEATURES ─── */
  .features-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 20px;
    margin-bottom: 80px;
  }

  @media (max-width: 640px) { .features-grid { grid-template-columns: 1fr; } }

  .feature-card {
    background: var(--surface);
    border: 1px solid var(--border2);
    border-radius: var(--radius);
    padding: 28px;
    display: flex;
    gap: 18px;
    align-items: flex-start;
    transition: border-color 0.2s;
  }

  .feature-card:hover { border-color: rgba(0,229,160,0.3); }

  .feature-icon-wrap {
    width: 44px; height: 44px;
    border-radius: 10px;
    background: rgba(0,229,160,0.08);
    border: 1px solid rgba(0,229,160,0.2);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 20px;
    flex-shrink: 0;
  }

  .feature-title {
    font-weight: 600;
    font-size: 15px;
    margin-bottom: 6px;
    color: var(--text);
  }

  .feature-desc {
    font-size: 13px;
    color: var(--text2);
    line-height: 1.7;
  }

  /* ─── SOURCES STRIP ─── */
  .sources-strip {
    position: relative;
    z-index: 1;
    border-top: 1px solid var(--border);
    border-bottom: 1px solid var(--border);
    background: var(--surface);
    padding: 24px 0;
    margin-bottom: 0;
    overflow: hidden;
  }

  .sources-inner {
    max-width: 1100px;
    margin: 0 auto;
    padding: 0 24px;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 48px;
    flex-wrap: wrap;
  }

  .source-item {
    display: flex;
    align-items: center;
    gap: 10px;
    font-size: 13px;
    color: var(--text2);
    font-weight: 500;
  }

  .source-item-icon {
    width: 28px; height: 28px;
    border-radius: 6px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 13px;
    font-weight: 700;
    color: white;
  }

  .si-indeed { background: #003a9b; }
  .si-linkedin { background: #0077b5; }
  .si-google { background: #ea4335; }
  .si-claude { background: linear-gradient(135deg, #7b61ff, #a855f7); }
  .si-apify { background: #1a1a2e; border: 1px solid #333; color: #00e5a0 !important; }

  .sources-label {
    font-family: var(--mono);
    font-size: 10px;
    color: var(--text3);
    letter-spacing: 2px;
    text-transform: uppercase;
    padding-right: 24px;
    border-right: 1px solid var(--border2);
  }

  /* ─── DIVIDER ─── */
  .section-divider {
    position: relative;
    z-index: 1;
    border: none;
    border-top: 1px solid var(--border);
    margin: 0;
  }

  /* ─── APP SECTION ─── */
  .app-section {
    position: relative;
    z-index: 1;
    max-width: 1100px;
    margin: 0 auto;
    padding: 80px 24px 80px;
  }

  /* ─── FORM CARD ─── */
  .form-card {
    background: var(--surface);
    border: 1px solid var(--border2);
    border-radius: var(--radius);
    padding: 32px;
    margin-bottom: 32px;
    position: relative;
    overflow: hidden;
  }

  .form-card::before {
    content: '';
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 2px;
    background: linear-gradient(90deg, var(--accent), var(--accent2), transparent);
  }

  .form-title {
    font-family: var(--display);
    font-size: 28px;
    letter-spacing: 1.5px;
    color: var(--text);
    margin-bottom: 6px;
  }

  .form-subtitle {
    color: var(--text2);
    font-size: 13px;
    margin-bottom: 28px;
  }

  .form-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 20px;
    margin-bottom: 20px;
  }

  @media (max-width: 640px) { .form-grid { grid-template-columns: 1fr; } }

  .form-group { display: flex; flex-direction: column; gap: 7px; }
  .form-group.full { grid-column: 1 / -1; }

  label {
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 1px;
    text-transform: uppercase;
    color: var(--text2);
  }

  input[type="text"], input[type="number"], select, textarea {
    background: var(--surface2);
    border: 1px solid var(--border2);
    border-radius: 8px;
    padding: 11px 14px;
    color: var(--text);
    font-family: var(--sans);
    font-size: 14px;
    outline: none;
    transition: border-color 0.2s, box-shadow 0.2s;
    width: 100%;
  }

  input:focus, select:focus, textarea:focus {
    border-color: var(--accent);
    box-shadow: 0 0 0 3px rgba(0,229,160,0.1);
  }

  select option { background: #1a1a24; }

  textarea {
    resize: vertical;
    min-height: 120px;
    font-size: 13px;
    line-height: 1.7;
  }

  .source-group { display: flex; gap: 10px; flex-wrap: wrap; }

  .source-toggle {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 9px 16px;
    border: 1px solid var(--border2);
    border-radius: 8px;
    cursor: pointer;
    transition: all 0.2s;
    font-size: 13px;
    font-weight: 500;
    color: var(--text2);
    user-select: none;
    background: var(--surface2);
  }

  .source-toggle input { display: none; }
  .source-toggle:hover { border-color: var(--accent); color: var(--text); }
  .source-toggle.active { border-color: var(--accent); background: rgba(0,229,160,0.08); color: var(--accent); }

  .source-icon {
    width: 18px; height: 18px;
    border-radius: 4px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 11px;
    font-weight: 700;
  }

  .icon-indeed { background: #003a9b; color: white; }
  .icon-linkedin { background: #0077b5; color: white; }
  .icon-google { background: #ea4335; color: white; }

  .upload-zone {
    border: 2px dashed var(--border2);
    border-radius: 10px;
    padding: 32px 24px;
    text-align: center;
    cursor: pointer;
    transition: all 0.25s;
    position: relative;
    background: var(--surface2);
  }

  .upload-zone:hover, .upload-zone.dragover {
    border-color: var(--accent);
    background: rgba(0,229,160,0.04);
  }

  .upload-zone input { position: absolute; inset: 0; opacity: 0; cursor: pointer; }
  .upload-icon { font-size: 28px; margin-bottom: 10px; display: block; }
  .upload-text { font-size: 14px; color: var(--text2); }
  .upload-text strong { color: var(--accent); }
  .upload-meta { font-size: 11px; color: var(--text3); margin-top: 5px; font-family: var(--mono); }

  .upload-filename {
    margin-top: 12px;
    font-family: var(--mono);
    font-size: 12px;
    color: var(--accent);
    display: none;
    align-items: center;
    justify-content: center;
    gap: 6px;
  }

  .upload-filename.visible { display: flex; }

  .btn-analyze {
    width: 100%;
    padding: 16px 32px;
    background: var(--accent);
    color: #0a0a0f;
    border: none;
    border-radius: 10px;
    font-family: var(--display);
    font-size: 20px;
    letter-spacing: 2px;
    cursor: pointer;
    transition: all 0.25s;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 10px;
    margin-top: 8px;
    position: relative;
    overflow: hidden;
  }

  .btn-analyze::after {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(90deg, transparent, rgba(255,255,255,0.15), transparent);
    transform: translateX(-100%);
    transition: transform 0.5s;
  }

  .btn-analyze:hover::after { transform: translateX(100%); }
  .btn-analyze:hover { background: #00ffb3; box-shadow: 0 0 30px rgba(0,229,160,0.4); transform: translateY(-1px); }
  .btn-analyze:disabled { opacity: 0.5; cursor: not-allowed; transform: none; }

  /* ─── STATUS ─── */
  .status-bar {
    display: none;
    background: var(--surface);
    border: 1px solid var(--border2);
    border-radius: var(--radius);
    padding: 24px 28px;
    margin-bottom: 32px;
  }

  .status-bar.visible { display: block; }

  .status-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 16px;
  }

  .status-title { font-family: var(--mono); font-size: 12px; color: var(--accent); letter-spacing: 1px; text-transform: uppercase; }

  .status-spinner {
    width: 16px; height: 16px;
    border: 2px solid var(--border2);
    border-top-color: var(--accent);
    border-radius: 50%;
    animation: spin 0.8s linear infinite;
  }

  @keyframes spin { to { transform: rotate(360deg); } }

  .status-steps { display: flex; flex-direction: column; gap: 10px; }

  .status-step { display: flex; align-items: center; gap: 12px; font-size: 13px; color: var(--text3); transition: color 0.3s; }
  .status-step.active { color: var(--text); }
  .status-step.done { color: var(--success); }

  .step-dot {
    width: 8px; height: 8px;
    border-radius: 50%;
    border: 1px solid var(--border2);
    flex-shrink: 0;
    transition: all 0.3s;
  }

  .status-step.active .step-dot { border-color: var(--accent); background: var(--accent); box-shadow: 0 0 8px var(--accent); animation: pulse-dot 1s ease-in-out infinite; }
  .status-step.done .step-dot { border-color: var(--success); background: var(--success); }

  @keyframes pulse-dot {
    0%,100% { box-shadow: 0 0 8px var(--accent); }
    50% { box-shadow: 0 0 18px var(--accent); }
  }

  /* ─── RESULTS ─── */
  .results-section { display: none; animation: fadeUp 0.5s ease forwards; }
  .results-section.visible { display: block; }

  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(20px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  .summary-row {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 16px;
    margin-bottom: 32px;
  }

  @media (max-width: 640px) { .summary-row { grid-template-columns: repeat(2, 1fr); } }

  .stat-card {
    background: var(--surface);
    border: 1px solid var(--border2);
    border-radius: var(--radius);
    padding: 20px;
    text-align: center;
    position: relative;
    overflow: hidden;
  }

  .stat-card::before {
    content: '';
    position: absolute;
    bottom: 0; left: 0; right: 0;
    height: 2px;
    background: linear-gradient(90deg, var(--accent), transparent);
    opacity: 0;
    transition: opacity 0.3s;
  }

  .stat-card:hover::before { opacity: 1; }

  .stat-value { font-family: var(--display); font-size: 38px; letter-spacing: 1px; color: var(--accent); line-height: 1; margin-bottom: 5px; }
  .stat-label { font-size: 11px; color: var(--text3); text-transform: uppercase; letter-spacing: 1px; font-weight: 600; }

  .matches-card {
    background: var(--surface);
    border: 1px solid var(--border2);
    border-radius: var(--radius);
    overflow: hidden;
    margin-bottom: 24px;
  }

  .card-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 18px 24px;
    border-bottom: 1px solid var(--border);
    background: var(--surface2);
  }

  .card-header-title { font-family: var(--display); font-size: 20px; letter-spacing: 1px; }

  .card-header-count {
    font-family: var(--mono);
    font-size: 11px;
    color: var(--text3);
    padding: 4px 10px;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 20px;
  }

  .matches-table { width: 100%; border-collapse: collapse; }

  .matches-table th {
    text-align: left;
    padding: 12px 20px;
    font-size: 10px;
    font-weight: 600;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    color: var(--text3);
    border-bottom: 1px solid var(--border);
    font-family: var(--mono);
  }

  .matches-table td { padding: 16px 20px; border-bottom: 1px solid var(--border); font-size: 13px; vertical-align: middle; }
  .matches-table tr:last-child td { border-bottom: none; }
  .matches-table tr { transition: background 0.15s; cursor: pointer; }
  .matches-table tr:hover td { background: rgba(255,255,255,0.02); }

  .rank-badge {
    width: 28px; height: 28px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: var(--mono);
    font-size: 12px;
    font-weight: 600;
    border: 1px solid var(--border2);
    color: var(--text2);
  }

  .rank-badge.top { border-color: var(--warn); color: var(--warn); background: rgba(255,201,71,0.08); }

  .job-title { font-weight: 500; color: var(--text); margin-bottom: 2px; }
  .job-company { font-size: 12px; color: var(--text2); display: flex; align-items: center; gap: 5px; }

  .match-bar-wrap { display: flex; align-items: center; gap: 10px; }
  .match-bar { flex: 1; height: 4px; background: var(--border2); border-radius: 2px; overflow: hidden; min-width: 70px; }
  .match-bar-fill { height: 100%; border-radius: 2px; transition: width 1s ease; }
  .match-pct { font-family: var(--mono); font-size: 12px; font-weight: 600; min-width: 36px; text-align: right; }

  .salary-chip { font-family: var(--mono); font-size: 11px; color: var(--text2); white-space: nowrap; }

  .source-pill { font-size: 10px; font-weight: 600; padding: 2px 8px; border-radius: 4px; text-transform: uppercase; letter-spacing: 0.5px; }
  .pill-indeed { background: rgba(0,58,155,0.25); color: #6699ff; }
  .pill-linkedin { background: rgba(0,119,181,0.2); color: #4db6f5; }
  .pill-google { background: rgba(234,67,53,0.15); color: #ff7b6e; }

  .view-btn { font-size: 11px; color: var(--accent); text-decoration: none; font-family: var(--mono); letter-spacing: 0.5px; display: flex; align-items: center; gap: 4px; white-space: nowrap; opacity: 0.7; transition: opacity 0.2s; }
  .view-btn:hover { opacity: 1; }

  .two-col { display: grid; grid-template-columns: 1fr 1fr; gap: 20px; margin-bottom: 24px; }
  @media (max-width: 640px) { .two-col { grid-template-columns: 1fr; } }

  .info-card { background: var(--surface); border: 1px solid var(--border2); border-radius: var(--radius); padding: 24px; }
  .info-card-title { font-family: var(--display); font-size: 18px; letter-spacing: 1px; margin-bottom: 16px; color: var(--text); }

  .skill-chips { display: flex; flex-wrap: wrap; gap: 8px; }

  .skill-chip {
    font-family: var(--mono);
    font-size: 11px;
    padding: 5px 12px;
    border-radius: 6px;
    border: 1px solid var(--border2);
    color: var(--text2);
    background: var(--surface2);
    transition: all 0.2s;
  }

  .skill-chip.gap-skill { border-color: rgba(255,107,53,0.4); color: var(--accent3); background: rgba(255,107,53,0.06); }

  .rec-card {
    background: var(--surface);
    border: 1px solid rgba(0,229,160,0.2);
    border-left: 3px solid var(--accent);
    border-radius: var(--radius);
    padding: 24px 28px;
    margin-bottom: 24px;
    position: relative;
    overflow: hidden;
  }

  .rec-card::before {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse at top left, rgba(0,229,160,0.04), transparent 60%);
    pointer-events: none;
  }

  .rec-label { font-family: var(--mono); font-size: 10px; color: var(--accent); letter-spacing: 2px; text-transform: uppercase; margin-bottom: 10px; }
  .rec-text { color: var(--text); font-size: 14px; line-height: 1.8; }

  .report-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    background: var(--surface);
    border: 1px solid var(--border2);
    border-radius: var(--radius);
    padding: 18px 24px;
  }

  .report-info { display: flex; align-items: center; gap: 14px; }

  .report-icon {
    width: 40px; height: 40px;
    border-radius: 8px;
    background: rgba(123,97,255,0.1);
    border: 1px solid rgba(123,97,255,0.25);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 18px;
  }

  .report-name { font-weight: 500; font-size: 14px; margin-bottom: 2px; }
  .report-meta { font-size: 11px; color: var(--text3); font-family: var(--mono); }

  .btn-download {
    padding: 9px 20px;
    background: transparent;
    border: 1px solid var(--accent);
    color: var(--accent);
    border-radius: 7px;
    font-family: var(--mono);
    font-size: 12px;
    cursor: pointer;
    transition: all 0.2s;
    text-decoration: none;
    display: flex;
    align-items: center;
    gap: 6px;
    letter-spacing: 0.5px;
  }

  .btn-download:hover { background: rgba(0,229,160,0.1); box-shadow: 0 0 16px rgba(0,229,160,0.2); }

  .error-card {
    display: none;
    background: rgba(255,71,87,0.06);
    border: 1px solid rgba(255,71,87,0.3);
    border-radius: var(--radius);
    padding: 20px 24px;
    margin-bottom: 24px;
    color: var(--danger);
    font-size: 13px;
    line-height: 1.6;
  }

  .error-card.visible { display: block; }
  .error-title { font-weight: 600; margin-bottom: 4px; font-family: var(--mono); text-transform: uppercase; font-size: 11px; letter-spacing: 1px; }

  .btn-new {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 9px 18px;
    border: 1px solid var(--border2);
    border-radius: 7px;
    font-family: var(--mono);
    font-size: 11px;
    color: var(--text2);
    cursor: pointer;
    background: transparent;
    transition: all 0.2s;
    letter-spacing: 0.5px;
  }

  .btn-new:hover { border-color: var(--accent); color: var(--accent); }

  .match-high .match-bar-fill { background: linear-gradient(90deg, var(--accent), #00b87a); }
  .match-high .match-pct { color: var(--accent); }
  .match-med .match-bar-fill { background: linear-gradient(90deg, var(--warn), #e0aa35); }
  .match-med .match-pct { color: var(--warn); }
  .match-low .match-bar-fill { background: linear-gradient(90deg, var(--accent3), #cc5520); }
  .match-low .match-pct { color: var(--accent3); }

  /* ─── FOOTER ─── */
  footer {
    position: relative;
    z-index: 1;
    text-align: center;
    padding: 40px 24px;
    border-top: 1px solid var(--border);
    font-size: 11px;
    color: var(--text3);
    font-family: var(--mono);
    letter-spacing: 0.5px;
  }

  .footer-logo {
    font-family: var(--display);
    font-size: 22px;
    letter-spacing: 2px;
    color: var(--text2);
    margin-bottom: 8px;
  }
</style>
</head>
<body>

<!-- ─── NAV ─── -->
<nav>
  <div class="nav-logo">
    <div class="nav-dot"></div>
    <span class="nav-logo-text">JOBIFY</span>
  </div>
  <div class="nav-links">
