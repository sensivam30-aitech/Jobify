      </div>
    </div>
    <div class="feature-card">
      <div class="feature-icon-wrap">🌐</div>
      <div>
        <div class="feature-title">Multi-Source Search</div>
        <p class="feature-desc">Choose Indeed, LinkedIn, Google Jobs — or all three. Cast a wider net or laser-focus on the platform you trust most.</p>
      </div>
    </div>
    <div class="feature-card">
      <div class="feature-icon-wrap">🎯</div>
      <div>
        <div class="feature-title">Smart Filtering</div>
        <p class="feature-desc">Filter by experience level, location, and number of listings. Get the signal you need without the noise.</p>
      </div>
    </div>
  </div>
</section>

<hr class="section-divider" />

<!-- ─── APP ─── -->
<div class="app-section" id="app">
  <div class="section-label">Job Matcher</div>
  <h2 class="section-title" style="margin-bottom:6px;">FIND YOUR BEST MATCHES</h2>
  <p style="color:var(--text2);font-size:13px;margin-bottom:32px;">Upload your résumé, set your criteria, and let AI do the rest.</p>

  <!-- FORM -->
  <div id="formSection">
    <div class="form-card">
      <div class="form-title">START YOUR SEARCH</div>
      <div class="form-subtitle">Fill in your details below — results appear on this page within 60 seconds.</div>

      <div class="form-grid">
        <div class="form-group">
          <label>Job Title / Role</label>
          <input type="text" id="jobTitle" placeholder="e.g. Senior React Developer" />
        </div>
        <div class="form-group">
          <label>Location</label>
          <input type="text" id="location" placeholder="e.g. Remote, New York, NY" />
        </div>
        <div class="form-group">
          <label>Jobs to Scrape</label>
          <select id="maxResults">
            <option value="10">10 listings</option>
            <option value="20" selected>20 listings</option>
            <option value="30">30 listings</option>
            <option value="50">50 listings</option>
          </select>
        </div>
        <div class="form-group">
          <label>Experience Level</label>
          <select id="experienceLevel">
            <option value="">Any level</option>
            <option value="entry">Entry level</option>
            <option value="mid">Mid level</option>
            <option value="senior" selected>Senior</option>
            <option value="executive">Executive / Director</option>
          </select>
        </div>
        <div class="form-group full">
          <label>Job Sources</label>
          <div class="source-group">
            <label class="source-toggle active" id="toggle-indeed">
              <input type="checkbox" id="src-indeed" checked onchange="updateToggle('indeed')" />
              <div class="source-icon icon-indeed">i</div>
              Indeed
            </label>
            <label class="source-toggle active" id="toggle-linkedin">
              <input type="checkbox" id="src-linkedin" checked onchange="updateToggle('linkedin')" />
              <div class="source-icon icon-linkedin">in</div>
              LinkedIn
            </label>
            <label class="source-toggle" id="toggle-google">
              <input type="checkbox" id="src-google" onchange="updateToggle('google')" />
              <div class="source-icon icon-google">G</div>
              Google Jobs
            </label>
          </div>
        </div>
        <div class="form-group full">
          <label>Key Skills (comma separated)</label>
          <input type="text" id="skills" placeholder="e.g. React, Node.js, TypeScript, REST APIs" />
        </div>
        <div class="form-group full">
          <label>Résumé / Skills Summary</label>
          <div style="margin-bottom:10px;">
  <input type="file" id="resumeFile" accept=".pdf,.doc,.docx,.txt" onchange="handleFileSelect(this)" style="width:100%;padding:12px;background:var(--surface2);border:1px solid var(--border2);border-radius:8px;color:var(--text);font-family:var(--mono);font-size:13px;cursor:pointer;" />
  <div id="uploadFilename" style="margin-top:6px;font-size:12px;color:var(--accent);font-family:var(--mono);display:none;">✓ <span id="uploadedName"></span></div>
</div>
<textarea id="resumeText" placeholder="…or paste your skills summary, experience, or résumé text here" style="margin-top:10px;"></textarea>
        </div>
      </div>

      <button class="btn-analyze" id="analyzeBtn" onclick="startAnalysis()">
        ⚡ ANALYZE JOBS
      </button>
    </div>
  </div>

  <!-- STATUS -->
  <div class="status-bar" id="statusBar">
    <div class="status-header">
      <div class="status-title">ANALYZING — PLEASE WAIT</div>
      <div class="status-spinner" id="spinner"></div>
    </div>
    <div class="status-steps">
      <div class="status-step" id="step1"><div class="step-dot"></div><span>Launching Apify scrapers across selected sources…</span></div>
      <div class="status-step" id="step2"><div class="step-dot"></div><span>Scraping job listings and extracting structured data…</span></div>
      <div class="status-step" id="step3"><div class="step-dot"></div><span>Sending listings to Claude for AI analysis…</span></div>
      <div class="status-step" id="step4"><div class="step-dot"></div><span>Ranking matches and identifying skill gaps…</span></div>
      <div class="status-step" id="step5"><div class="step-dot"></div><span>Generating full HTML report…</span></div>
    </div>
  </div>

  <!-- ERROR -->
  <div class="error-card" id="errorCard">
    <div class="error-title">⚠ Analysis Failed</div>
    <div id="errorMsg">Something went wrong. Please try again.</div>
  </div>

  <!-- RESULTS -->
  <div class="results-section" id="resultsSection">
    <div class="section-label">ANALYSIS RESULTS</div>
    <div class="summary-row">
      <div class="stat-card"><div class="stat-value" id="statScraped">—</div><div class="stat-label">Jobs Scraped</div></div>
      <div class="stat-card"><div class="stat-value" id="statMatches">—</div><div class="stat-label">Relevant Matches</div></div>
      <div class="stat-card"><div class="stat-value" id="statTopScore">—</div><div class="stat-label">Top Match %</div></div>
      <div class="stat-card"><div class="stat-value" id="statSources">—</div><div class="stat-label">Sources Used</div></div>
    </div>

    <div class="matches-card" style="margin-bottom:24px;">
      <div class="card-header">
        <div class="card-header-title">TOP MATCHES</div>
        <div class="card-header-count" id="matchCount">0 jobs</div>
      </div>
      <div style="overflow-x:auto;">
        <table class="matches-table">
          <thead>
            <tr>
              <th>#</th><th>Role</th><th>Match</th><th>Salary</th><th>Source</th><th>Link</th>
            </tr>
          </thead>
          <tbody id="matchesBody"></tbody>
        </table>
      </div>
    </div>

    <div class="two-col">
      <div class="info-card">
        <div class="info-card-title">SKILL GAPS</div>
        <div class="skill-chips" id="skillGaps"></div>
      </div>
      <div class="info-card">
        <div class="info-card-title">YOUR MATCHED SKILLS</div>
        <div class="skill-chips" id="matchedSkills"></div>
      </div>
    </div>

    <div class="rec-card" id="recCard">
      <div class="rec-label">AI Recommendation</div>
      <div class="rec-text" id="recText">—</div>
    </div>

    <div class="report-row">
      <div class="report-info">
        <div class="report-icon">📊</div>
        <div>
          <div class="report-name">Full Analysis Report</div>
          <div class="report-meta" id="reportMeta">HTML · Generated just now</div>
        </div>
      </div>
      <div style="display:flex;gap:10px;align-items:center;">
        <a class="btn-download" id="reportLink" href="#" target="_blank">↗ OPEN REPORT</a>
        <button class="btn-new" onclick="resetForm()">← NEW SEARCH</button>
      </div>
    </div>
  </div>
</div>

<!-- ─── FOOTER ─── */
<footer>
  <div class="footer-logo">JOBIFY</div>
  Browse. Scrape. Succeed. &nbsp;·&nbsp; Powered by Claude AI + Apify &nbsp;·&nbsp; Real-time job intelligence
</footer>

<script>
// ─── TOGGLES ──────────────────────────────────────────────────────
function updateToggle(src) {
  const cb = document.getElementById('src-' + src);
  document.getElementById('toggle-' + src).classList.toggle('active', cb.checked);
}

// ─── FILE UPLOAD ──────────────────────────────────────────────────
const uploadZone = document.getElementById('uploadZone');
uploadZone.addEventListener('dragover', e => { e.preventDefault(); uploadZone.classList.add('dragover'); });
uploadZone.addEventListener('dragleave', () => uploadZone.classList.remove('dragover'));
uploadZone.addEventListener('drop', e => {
  e.preventDefault();
  uploadZone.classList.remove('dragover');
  const file = e.dataTransfer.files[0];
  if (file) setFile(file);
});

let resumeFileData = null;
function handleFileSelect(input) { if (input.files[0]) setFile(input.files[0]); }
function setFile(file) {
  console.log("File selected:", file.name, file.size);
  resumeFileData = file;
  document.getElementById('uploadedName').textContent = file.name;
  document.getElementById('uploadFilename').classList.add('visible');
}

// ─── STEP ANIMATION ───────────────────────────────────────────────
let stepTimers = [];
function animateSteps(durationMs) {
  const steps = ['step1','step2','step3','step4','step5'];
  const interval = durationMs / steps.length;
  steps.forEach((id, i) => {
    const t = setTimeout(() => {
      if (i > 0) {
        document.getElementById(steps[i-1]).classList.remove('active');
        document.getElementById(steps[i-1]).classList.add('done');
      }
      document.getElementById(id).classList.add('active');
    }, i * interval);
    stepTimers.push(t);
  });
}
function clearStepTimers() { stepTimers.forEach(clearTimeout); stepTimers = []; }
function finishSteps() {
  ['step1','step2','step3','step4','step5'].forEach(id => {
    document.getElementById(id).classList.remove('active');
    document.getElementById(id).classList.add('done');
  });
  document.getElementById('spinner').style.display = 'none';
}
function resetSteps() {
  ['step1','step2','step3','step4','step5'].forEach(id => {
    document.getElementById(id).classList.remove('active','done');
  });
  document.getElementById('spinner').style.display = '';
}

// ─── ANALYSIS ─────────────────────────────────────────────────────
async function startAnalysis() {
  const jobTitle   = document.getElementById('jobTitle').value.trim();
  const location   = document.getElementById('location').value.trim();
  const skills     = document.getElementById('skills').value.trim();
  const resumeTxt  = document.getElementById('resumeText').value.trim();
  const maxResults = parseInt(document.getElementById('maxResults').value);
  const expLevel   = document.getElementById('experienceLevel').value;
  const sources = [];
  if (document.getElementById('src-indeed').checked)   sources.push('indeed');
  if (document.getElementById('src-linkedin').checked) sources.push('linkedin');
  if (document.getElementById('src-google').checked)   sources.push('google');
  if (sources.length === 0)          { alert('Please select at least one job source.'); return; }
  document.getElementById('formSection').style.display = 'none';
  document.getElementById('statusBar').classList.add('visible');
  document.getElementById('resultsSection').classList.remove('visible');
  document.getElementById('errorCard').classList.remove('visible');
  resetSteps();
  animateSteps(45000);
  const formData = new FormData();
  formData.append('jobTitle', jobTitle);
  formData.append('location', location);
  formData.append('skills', skills);
  formData.append('resume', resumeTxt);
  formData.append('maxResults', maxResults);
  formData.append('experienceLevel', expLevel);
  if (resumeFileData) formData.append('resumeFile', resumeFileData);
  try {
    const res = await fetch('/api/jobs/analyze', { method: 'POST', body: formData });
    const data = await res.json();
    clearStepTimers();
    finishSteps();
    setTimeout(() => {
      document.getElementById('statusBar').classList.remove('visible');
      else renderResults(data);
    }, 800);
  } catch(err) {
    clearStepTimers();
    finishSteps();
    setTimeout(() => {
      document.getElementById('statusBar').classList.remove('visible');
      showError('Network error: ' + err.message);
    }, 500);
  }
}

function readFileAsText(file) {
  return new Promise((resolve, reject) => {
    const r = new FileReader();
    r.onload = e => resolve(e.target.result);
    r.onerror = reject;
    r.readAsText(file);
  });
}

// ─── RENDER RESULTS ────────────────────────────────────────────────
function renderResults(data) {
  const analysis  = data.analysis || {};
  const matches   = analysis.matches || [];
  const scraped   = data.totalScraped || data.rawCount || matches.length;
  const relevant  = data.relevantCount || matches.length;
  const topScore  = matches.length > 0 ? (matches[0].matchPercentage || matches[0].score || 0) : 0;
  const sourcesUsed = data.sources || data.sourcesUsed || 1;

  document.getElementById('statScraped').textContent  = scraped;
  document.getElementById('statMatches').textContent  = relevant;
  document.getElementById('statTopScore').textContent = topScore + '%';
  document.getElementById('statSources').textContent  = sourcesUsed;
  document.getElementById('matchCount').textContent   = matches.length + ' jobs';

  const tbody = document.getElementById('matchesBody');
  tbody.innerHTML = '';
  matches.forEach((job, i) => {
    const pct     = job.matchPercentage || job.score || 0;
    const cls     = pct >= 80 ? 'match-high' : pct >= 60 ? 'match-med' : 'match-low';
    const salary  = job.salary || job.salaryRange || 'Not listed';
    const source  = (job.source || 'indeed').toLowerCase();
    const url     = job.url || job.jobUrl || job.link || '#';
    const title   = job.title || job.jobTitle || 'Untitled';
    const company = job.company || job.companyName || '—';
    tbody.innerHTML += `
      <tr onclick="window.open('${url}','_blank')">
        <td><div class="rank-badge ${i<3?'top':''}">${i+1}</div></td>
        <td><div class="job-title">${escHtml(title)}</div><div class="job-company">${escHtml(company)}</div></td>
        <td class="${cls}">
          <div class="match-bar-wrap">
            <div class="match-bar"><div class="match-bar-fill" style="width:${pct}%"></div></div>
            <div class="match-pct">${pct}%</div>
          </div>
        </td>
        <td><div class="salary-chip">${escHtml(salary)}</div></td>
        <td><span class="source-pill pill-${source}">${source}</span></td>
        <td><a class="view-btn" href="${url}" target="_blank" onclick="event.stopPropagation()">↗ View</a></td>
      </tr>`;
  });

  const gaps = analysis.skillGaps || data.skillGaps || [];
  document.getElementById('skillGaps').innerHTML =
    gaps.map(s => `<div class="skill-chip gap-skill">${escHtml(s)}</div>`).join('') ||
    '<div class="skill-chip" style="color:var(--text3)">None identified</div>';

  const matched = analysis.matchedSkills || analysis.strongSkills || data.matchedSkills || [];
  document.getElementById('matchedSkills').innerHTML =
    matched.map(s => `<div class="skill-chip">${escHtml(s)}</div>`).join('') ||
    '<div class="skill-chip" style="color:var(--text3)">—</div>';

  const rec = analysis.recommendation || data.recommendation || '';
  document.getElementById('recText').textContent = rec || 'No recommendation generated.';

  if (data.reportPath || data.reportUrl) {
    document.getElementById('reportLink').href = data.reportUrl || ('/report?path=' + encodeURIComponent(data.reportPath));
  }
  document.getElementById('reportMeta').textContent = `HTML · Generated ${new Date().toLocaleString()}`;

  document.getElementById('resultsSection').classList.add('visible');
  document.getElementById('resultsSection').scrollIntoView({ behavior: 'smooth', block: 'start' });
}

function showError(msg) {
  document.getElementById('errorMsg').textContent = msg;
  document.getElementById('errorCard').classList.add('visible');
  document.getElementById('formSection').style.display = '';
}

function resetForm() {
  document.getElementById('resultsSection').classList.remove('visible');
  document.getElementById('errorCard').classList.remove('visible');
  document.getElementById('formSection').style.display = '';
  window.scrollTo({ top: 0, behavior: 'smooth' });
}

function escHtml(str) {
  if (!str) return '';
  return String(str).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
}
</script>
</body>
</html>
